{
	"name": "doc-analyzer-demo",
	"version": "0.0.1",
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.11",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome lint src/ && eslint src/",
		"lint:svelte": "eslint 'src/**/*.svelte'",
		"format": "biome format --write src/ && prettier --write 'src/**/*.svelte'",
		"format:check": "biome format src/ && prettier --check 'src/**/*.svelte'"
	},
	"type": "module",
	"dependencies": {
		"unpdf": "^1.4.0"
	}
}
